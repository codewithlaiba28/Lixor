generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

model RestaurantTable {
  id           String        @id @default(cuid())
  tableNumber  Int           @unique
  capacity     Int
  isActive     Boolean       @default(true)
  reservations Reservation[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Float
  category    String      // Starters, Main Course, Desserts, Drinks
  imageUrl    String
  isAvailable Boolean     @default(true)
  orderItems  OrderItem[]
}

model Reservation {
  id              String          @id @default(cuid())
  guestName       String
  phone           String
  email           String
  date            DateTime
  timeSlot        String          // 12:00 PM, 1:00 PM, 2:00 PM, 6:00 PM, 7:00 PM, 8:00 PM, 9:00 PM
  guests          Int
  specialRequests String?
  status          String          @default("Pending") // Pending, Confirmed, Cancelled
  preOrderItems   Json?           // Optional: [ { id, name, price, quantity } ]
  createdAt       DateTime        @default(now())
  
  table           RestaurantTable @relation(fields: [tableId], references: [id])
  tableId         String

  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  phone        String
  address      String
  orderType    String      // Delivery, Takeaway
  status       String      @default("Pending") // Pending, Preparing, Out for Delivery, Delivered
  totalAmount  Float
  createdAt    DateTime    @default(now())
  items        OrderItem[]

  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  
  orders        Order[]
  reservations  Reservation[]
  chatMessages  ChatMessage[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model OrderItem {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
  quantity   Int
  price      Float
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user, assistant
  content   String
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Document {
  id        String                 @id @default(cuid())
  content   String
  metadata  Json                   @default("{}")
  embedding Unsupported("vector(384)")
}
